{
  "name": "pay-me-back-agent",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "set HARDHAT_DISABLE_TELEMETRY_PROMPT=true&& hardhat compile",
    "compile": "set HARDHAT_DISABLE_TELEMETRY_PROMPT=true&& hardhat compile",
    "deploy:xlayer": "set HARDHAT_DISABLE_TELEMETRY_PROMPT=true&& hardhat run scripts/deploy.ts --network xlayer",
    "agent:start": "ts-node agent/index.ts"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.1.0",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.5"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@types/node": "^22.10.1",
    "ethereum-cryptography": "^3.2.0",
    "hardhat": "^2.22.17",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
